meta {
  name: Execute manual conversion
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/smart-convert/execute
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "target_wallet_id": "f3d961a7-4759-48b3-a8ec-6ef4a92794dd",
    "source_wallet_id": "4062dc10-71c1-431b-9100-9b0c027fcdec",
    "source_currency": "USD",
    "target_currency":"NGN",
    "amount": "1"
  //   "amount_type": "target"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
