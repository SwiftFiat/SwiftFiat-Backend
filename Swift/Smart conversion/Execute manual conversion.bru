meta {
  name: Execute manual conversion
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/smart-convert/execute
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "target_wallet_id": "3756912c-c798-42d8-a722-bb9fc895da49",
