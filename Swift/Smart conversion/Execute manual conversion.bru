meta {
  name: Execute manual conversion
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/smart-convert/execute
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "source_wallet_id": "f19bd079-eaaa-4651-802f-4a6790485978",
