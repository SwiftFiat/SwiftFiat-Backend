meta {
  name: Execute manual conversion
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/smart-convert/execute
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "source_currency": "USD",
    "target_currency":"NGN",
    "amount": "500",
    "pin": "1234"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
