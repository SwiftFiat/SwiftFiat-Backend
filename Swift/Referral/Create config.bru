meta {
  name: Create config
  type: http
  seq: 3
}

post {
  url: {{BaseURl}}/referral/admin/create-referral-config
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "referral_percentage_earned_per_conversion": "0.05",
    "referral_amount": "1000"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
