meta {
  name: Assign user to vip level
  type: http
  seq: 3
}

post {
  url: {{BaseURl}}/rate-manager/admin/vip-assignments
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "user_id": 1,
    "vip_level_id": "d8cfb252-6a81-4a80-a691-46be3afb7cc5"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
