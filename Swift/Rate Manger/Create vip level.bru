meta {
  name: Create vip level
  type: http
  seq: 1
}

post {
  url: {{BaseURl}}/rate-manager/admin/vip-levels
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "level_name": "test level",
    "level_code": "TSL",
    "level_rank": 1,
    "min_transaction_volume": "500"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
