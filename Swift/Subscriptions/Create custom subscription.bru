meta {
  name: Create custom subscription
  type: http
  seq: 3
}

post {
  url: {{BaseURl}}/subscriptions/custom
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_id": "b134c7c8-7a49-433a-bd00-1cf214795603",
    "merchant_name": "adidas",
    "display_name": "Adidas",
    "category": "streaming",
    "amount": 100,
    "currency": "USD",
    "billing_cycle": "monthly",
    "first_charge_date": "2026-03-03T00:00:00Z"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
