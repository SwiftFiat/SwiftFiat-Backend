meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_brand": "Mastercard",
    "funding_amount": "100",
    "card_plan_id": 1,
    "card_name": "test card",
    "source_wallet_id": "e6b75c0c-ba75-4696-b249-732cd1b48764"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
