meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards/create
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_plan_id": 1,
    "card_name": "Test card",
    "card_holder_id": "04854795190b47119629f53e65f27e33",
    "funding_amount": "4",
    "idempotency_key": "36974984-345",
    "idempotency_key_2": "345"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
