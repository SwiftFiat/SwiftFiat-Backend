meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards/create
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_plan_id": 1,
    "card_name": "test card",
    "card_holder_id": "a61026cbc60347d9a1a71961ece2f7e1",
    "funding_amount": "4"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
