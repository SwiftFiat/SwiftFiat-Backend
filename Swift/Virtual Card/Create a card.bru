meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards/create
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_plan_id": 2,
    "card_name": "Test card",
    "color": "red",
    "card_holder_id": "f60303fa469a4d9abb76ccf8841265a0",
    "funding_amount": "4",
    "idempotency_key": "36974984-3457",
    "idempotency_key_2": "345"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
