meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_plan_id": 1,
    "card_name": "Leonard card",
    "card_holder_id": "da2941675109405fabbe9454a16ccee8",
    "funding_amount": "3"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
