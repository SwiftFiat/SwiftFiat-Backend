meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_brand": "Mastercard",
    "funding_amount": "3",
    "card_plan_id": 1,
    "card_name": "Green card",
    "source_wallet_id": "c7685d70-521f-438b-a800-5ee56b9f943e"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
