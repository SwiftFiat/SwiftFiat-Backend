meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_plan_id": 1,
    "card_name": "Green card",
    "card_holder_id": "f5d9562d6ee849e7adc20e6ffd6b8c5d",
    "funding_amount": "3"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
