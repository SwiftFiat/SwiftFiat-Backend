meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards/create
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_plan_id": 2,
    "card_name": "test card",
    "card_holder_id": "307357513b1743919d055a34a0c8d2e7",
    "funding_amount": "4"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
