meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards/create
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_plan_id": 1,
    "card_name": "test card",
    "card_holder_id": "933c5dfd760f4e0da4d13e474a6b352b",
    "funding_amount": "4"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
