meta {
  name: Create a card
  type: http
  seq: 2
}

post {
  url: {{BaseURl}}/cards
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "card_plan_id": 1,
    "card_name": "Test card",
    "card_holder_id": "11e6c67920a5408d86756b7e4826fd69",
    "funding_amount": "3"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
