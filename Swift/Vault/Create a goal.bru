meta {
  name: Create a goal
  type: http
  seq: 1
}

post {
  url: {{BaseURl}}/vault/goals
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Buy Car",
    "description": "",
    "target_amount": "400000",
    "currency": "NGN",
    "recurring_rule": {
      "enabled": true,
      "amount": "2000",
      "interval": "daily",
      "time_of_day": "15:42"
    },
    "vault_type": "flexible"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
