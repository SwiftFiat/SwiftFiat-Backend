meta {
  name: Create qrcode
  type: http
  seq: 1
}

post {
  url: {{BaseURl}}/qr-codes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
      "network": "btc",
      "crypto_currency": "BTC",
      "bank_account_id": "01139375-60ca-4065-86f8-437150ae31ce",
      "label": "My Test Payment QR"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
