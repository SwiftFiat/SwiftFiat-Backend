meta {
  name: Create qrcode
  type: http
  seq: 1
}

post {
  url: {{BaseURl}}/qr-codes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
      "network": "btc",
      "crypto_currency": "BTC",
      "bank_account_id": "c379b96f-e862-450c-8fa1-fec38bf65b23",
      "label": "My Test Payment QR",
    "amount": "1"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
