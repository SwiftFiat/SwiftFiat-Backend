meta {
  name: Create qrcode
  type: http
  seq: 1
}

post {
  url: {{BaseURl}}/qr-codes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
      "network": "btc",
      "crypto_currency": "BTC",
      "bank_account_id": "c5a38c85-f766-4ed4-b303-46bc9a7b1b0a",
      "label": "My Test Payment QR"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
