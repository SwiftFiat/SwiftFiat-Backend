meta {
  name: Get banks
  type: http
  seq: 3
}

get {
  url: {{BaseURl}}/wallets/banks
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: Get Banks
  
  request: {
    url: {{BaseURl}}/wallets/banks
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      access-control-allow-credentials: true
