      access-control-allow-methods: POST, OPTIONS, GET, PUT, DELETE, PATCH
      access-control-allow-origin: *
      content-type: application/json; charset=utf-8
      date: Mon, 16 Feb 2026 08:02:43 GMT
      transfer-encoding: chunked
    }
  
    status: {
      code: 200
      text: OK
    }
  
