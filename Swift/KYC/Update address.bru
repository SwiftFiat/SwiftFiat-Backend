meta {
  name: Update address
  type: http
  seq: 5
}

post {
  url: {{BaseURl}}/kyc/upload-address-proof
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  proof_type: utility_bill
  file: @file(/home/bontus/Documents/cpp/player.png)
  state: Abia
  lga: Bende
  house_number: 2
  street_name: Aada
  nearest_landmark: landmark
  postal_code: 123456
  city: Aba
}

settings {
  encodeUrl: true
  timeout: 0
}
