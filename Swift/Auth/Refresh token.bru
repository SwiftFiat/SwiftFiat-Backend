meta {
  name: Refresh token
  type: http
  seq: 17
}

post {
  url: {{BaseURl}}/auth/refresh
  body: json
  auth: inherit
}

body:json {
  {
    "refresh_token": "67560caf4343e117840a6aef8b1b9d1c376da39519ac2724ed0eadfeec90b724"
  }
}

tests {
  const body = res.body;
  bru.setEnvVar("token", body.data.access_token);
  
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: example
  
  request: {
