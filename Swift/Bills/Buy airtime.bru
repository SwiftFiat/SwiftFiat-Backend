meta {
  name: Buy airtime
  type: http
  seq: 1
}

post {
  url: {{BaseURl}}/bills/buy-airtime
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "service_id": "mtn",
    "phone": "08011111111",
    "amount": 100,
    "pin": "1234",
    "use_reward_points": true,
    "points_to_use": 2,
    "idempotency_key": "9e0338-87976w"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
